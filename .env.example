# ============================================================
# Payment Gateway Platform — Environment Variables (Example)
# Copy this file to .env and fill in the values
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# Database Connection String for Prisma (SQLite)
# Example: file:./dev.db
DATABASE_URL="file:./dev.db"

# Session / Auth
SESSION_SECRET=
JWT_SECRET=
JWT_EXPIRES_IN=24h

# API
API_VERSION=v1
# Payment Session & Fintech Defaults
SESSION_TTL_MINUTES=15
DEFAULT_CURRENCY=INR

# Smart Payment Routing
MAX_PAYMENT_RETRIES=3

# Risk Score System Thresholds
RISK_THRESHOLD_MEDIUM=25
RISK_THRESHOLD_HIGH=50
RISK_THRESHOLD_CRITICAL=75
MIN_HIGH_VALUE_TRANSACTION=50000

# Subscriptions & Escrow
SUBSCRIPTION_BILLING_BATCH_SIZE=50
ESCROW_DEFAULT_HOLD_DAYS=7

# Brevo Email Configuration
BREVO_API_KEY=your_brevo_api_key_here
EMAIL_SENDER_NAME="PaySim Platform"
EMAIL_SENDER_ADDR="noreply@yourdomain.com"
