generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model admins {
  id            Int            @id @default(autoincrement())
  uuid          String         @unique(map: "uq_admins_uuid")
  name          String        
  email         String         @unique(map: "uq_admins_email")
  password_hash String        
  role          String         @default("admin")
  created_at    DateTime       @default(now())
  updated_at    DateTime       @default(now())
  fraud_alerts  fraud_alerts[]

  @@index([role], map: "idx_admins_role")
}

model api_keys {
  id              Int               @id @default(autoincrement())
  merchant_app_id Int
  key_prefix      String           
  key_hash        String           
  key_type        String
  is_active       Boolean           @default(true)
  expires_at      DateTime?        
  last_used_at    DateTime?        
  created_at      DateTime          @default(now())
  merchant_apps   merchant_apps     @relation(fields: [merchant_app_id], references: [id], onDelete: Cascade)

  @@index([is_active], map: "idx_ak_active")
  @@index([merchant_app_id], map: "idx_ak_merchant_app")
  @@index([key_prefix], map: "idx_ak_prefix")
}

model api_logs {
  id               Int            @id @default(autoincrement())
  merchant_app_id  Int?
  request_id       String         @unique(map: "uq_al_request_id")
  method           String        
  endpoint         String        
  status_code      Int           
  ip_address       String        
  request_body     String?       
  response_body    String?       
  response_time_ms Int            @default(0)
  created_at       DateTime       @default(now())
  merchant_apps    merchant_apps? @relation(fields: [merchant_app_id], references: [id])

  @@index([created_at], map: "idx_al_created")
  @@index([endpoint], map: "idx_al_endpoint")
  @@index([ip_address], map: "idx_al_ip")
  @@index([merchant_app_id], map: "idx_al_merchant_app")
  @@index([status_code], map: "idx_al_status_code")
}

model bank_accounts {
  id                  Int           @id @default(autoincrement())
  customer_id         Int
  account_number_hash String                    
  account_last_four   String                    
  bank_name           String                    
  ifsc_code           String? 
  account_holder_name String                    
  account_type        String        @default("savings")
  balance             Float         @default(0.00)
  status              String        @default("active")
  created_at          DateTime      @default(now())
  updated_at          DateTime      @default(now())
  customers           customers     @relation(fields: [customer_id], references: [id])

  @@index([customer_id], map: "idx_ba_customer")
  @@index([ifsc_code], map: "idx_ba_ifsc")
  @@index([status], map: "idx_ba_status")
}

model credit_cards {
  id               Int           @id @default(autoincrement())
  customer_id      Int
  card_number_hash String                 
  card_last_four   String                 
  card_brand       String
  cardholder_name  String                 
  expiry_month     String                  
  expiry_year      String                 
  credit_limit     Float                 @default(0.00)
  used_credit      Float                 @default(0.00)
  status           String        @default("active")
  created_at       DateTime                @default(now())
  updated_at       DateTime                @default(now())
  customers        customers               @relation(fields: [customer_id], references: [id])

  @@index([customer_id], map: "idx_cc_customer")
  @@index([card_last_four], map: "idx_cc_last_four")
  @@index([status], map: "idx_cc_status")
}

model customers {
  id               Int                @id @default(autoincrement())
  uuid             String             @unique(map: "uq_customers_uuid")
  first_name       String            
  last_name        String            
  email            String             @unique(map: "uq_customers_email")
  phone            String?            
  password_hash    String            
  pin_hash         String?           
  status           String             @default("active")
  created_at       DateTime           @default(now())
  updated_at       DateTime           @default(now())
  bank_accounts    bank_accounts[]
  credit_cards     credit_cards[]
  fraud_alerts     fraud_alerts[]
  payment_methods  payment_methods[]
  payment_sessions payment_sessions[]
  transactions     transactions[]
  wallets          wallets[]
  escrowAccounts   escrow_accounts?
  subscriptions    subscriptions[]
  paymentAttempts  payment_attempts[]
  riskScores       risk_scores?
  auditLogs        audit_logs[]

  @@index([phone], map: "idx_customers_phone")
  @@index([status], map: "idx_customers_status")
}

model fraud_alerts {
  id             Int           @id @default(autoincrement())
  transaction_id Int?
  customer_id    Int?
  alert_type     String
  severity       String        @default("medium")
  description    String                 
  status         String        @default("open")
  resolved_by    Int?
  resolved_at    DateTime?              
  created_at     DateTime                @default(now())
  customers      customers?              @relation(fields: [customer_id], references: [id])
  admins         admins?                 @relation(fields: [resolved_by], references: [id])
  transactions   transactions?           @relation(fields: [transaction_id], references: [id])

  @@index([resolved_by])
  @@index([customer_id], map: "idx_fa_customer")
  @@index([severity], map: "idx_fa_severity")
  @@index([status], map: "idx_fa_status")
  @@index([transaction_id], map: "idx_fa_transaction")
  @@index([alert_type], map: "idx_fa_type")
}

model merchant_apps {
  id               Int           @id @default(autoincrement())
  merchant_id      Int
  app_name         String                   
  app_uuid         String                    @unique(map: "uq_ma_app_uuid")
  website_url      String?                  
  callback_url     String                   
  environment      String        @default("sandbox")
  status           String        @default("active")
  created_at       DateTime                  @default(now())
  updated_at       DateTime                  @default(now())
  api_keys         api_keys[]
  api_logs         api_logs[]
  merchants        merchants                 @relation(fields: [merchant_id], references: [id])
  payment_sessions payment_sessions[]

  @@index([environment], map: "idx_ma_environment")
  @@index([merchant_id], map: "idx_ma_merchant")
}

model merchants {
  id             Int           @id @default(autoincrement())
  uuid           String           @unique(map: "uq_merchants_uuid")
  business_name  String          
  business_email String           @unique(map: "uq_merchants_business_email")
  phone          String?          
  password_hash  String          
  business_type  String?         
  status         String @default("active")
  created_at     DateTime         @default(now())
  updated_at     DateTime         @default(now())
  merchant_apps  merchant_apps[]
  settlements    settlements[]
  transactions   transactions[]
  paymentSplits  payment_splits[]
  escrowAccounts escrow_accounts?
  subscriptions  subscriptions[]

  @@index([status], map: "idx_merchants_status")
}

model payment_methods {
  id              Int           @id @default(autoincrement())
  customer_id     Int
  method_type     String
  instrument_id   Int
  is_default      Boolean                     @default(false)
  status          String        @default("active")
  created_at      DateTime                    @default(now())
  updated_at      DateTime                    @default(now())
  customers       customers                   @relation(fields: [customer_id], references: [id])
  transactions    transactions[]
  subscriptions   subscriptions[]
  paymentAttempts payment_attempts[]

  @@unique([method_type, instrument_id], map: "uq_pm_type_instrument")
  @@index([customer_id], map: "idx_pm_customer")
  @@index([status], map: "idx_pm_status")
}

model payment_sessions {
  id              Int           @id @default(autoincrement())
  session_id      String                  @unique(map: "uq_ps_session_id")
  merchant_app_id Int
  customer_id     Int?
  amount          Float                
  currency        String                  @default("INR")
  description     String?                
  status          String @default("pending")
  callback_url    String                 
  metadata        String?
  expires_at      DateTime               
  created_at      DateTime                @default(now())
  updated_at      DateTime                @default(now())
  customers       customers?              @relation(fields: [customer_id], references: [id])
  merchant_apps   merchant_apps           @relation(fields: [merchant_app_id], references: [id])
  transactions    transactions[]
  paymentAttempts payment_attempts[]

  @@index([customer_id], map: "idx_ps_customer")
  @@index([expires_at], map: "idx_ps_expires")
  @@index([merchant_app_id], map: "idx_ps_merchant_app")
  @@index([status], map: "idx_ps_status")
}

model refunds {
  id                Int           @id @default(autoincrement())
  refund_id         String                    @unique(map: "uq_refunds_refund_id")
  transaction_id    Int
  amount            Float                  
  currency          String                    @default("INR")
  status            String            @default("initiated")
  reason            String?                  
  initiated_by      Int
  initiated_by_type String
  created_at        DateTime                  @default(now())
  updated_at        DateTime                  @default(now())
  transactions      transactions              @relation(fields: [transaction_id], references: [id])

  @@index([initiated_by_type, initiated_by], map: "idx_refunds_initiator")
  @@index([status], map: "idx_refunds_status")
  @@index([transaction_id], map: "idx_refunds_txn")
}

model settlements {
  id              Int           @id @default(autoincrement())
  settlement_id   String             @unique(map: "uq_settlements_id")
  merchant_id     Int
  total_amount    Float           
  fee_amount      Float            @default(0.00)
  net_amount      Float           
  currency        String             @default("INR")
  status          String @default("pending")
  settlement_date DateTime           
  created_at      DateTime           @default(now())
  updated_at      DateTime           @default(now())
  merchants       merchants          @relation(fields: [merchant_id], references: [id])

  @@index([settlement_date], map: "idx_settlements_date")
  @@index([merchant_id], map: "idx_settlements_merchant")
  @@index([status], map: "idx_settlements_status")
}

model transactions {
  id                   Int           @id @default(autoincrement())
  txn_id               String                      @unique(map: "uq_txn_txn_id")
  session_id           Int?
  customer_id          Int
  merchant_id          Int?
  receiver_id          Int?
  receiver_type        String?
  payment_method_id    Int
  amount               Float                    
  currency             String                      @default("INR")
  txn_type             String       @default("payment")
  status               String         @default("initiated")
  verified_at          DateTime?                  
  mode                 String
  failure_reason       String?                    
  gateway_ref          String?                    
  created_at           DateTime                    @default(now())
  updated_at           DateTime                    @default(now())
  fraud_alerts         fraud_alerts[]
  refunds              refunds[]
  customers            customers                   @relation(fields: [customer_id], references: [id])
  merchants            merchants?                  @relation(fields: [merchant_id], references: [id])
  payment_methods      payment_methods             @relation(fields: [payment_method_id], references: [id])
  payment_sessions     payment_sessions?           @relation(fields: [session_id], references: [id])
  paymentSplits        payment_splits[]
  escrowTransactions   escrow_transactions?
  subscriptionPayments subscription_payments?
  paymentAttempts      payment_attempts[]

  @@index([created_at], map: "idx_txn_created")
  @@index([customer_id], map: "idx_txn_customer")
  @@index([merchant_id], map: "idx_txn_merchant")
  @@index([mode], map: "idx_txn_mode")
  @@index([payment_method_id], map: "idx_txn_pm")
  @@index([session_id], map: "idx_txn_session")
  @@index([status], map: "idx_txn_status")
  @@index([txn_type, status], map: "idx_txn_type_status")
}

model wallets {
  id          Int           @id @default(autoincrement())
  customer_id Int
  wallet_id   String         @unique(map: "uq_wallets_wallet_id")
  balance     Float        @default(0.00)
  currency    String         @default("INR")
  status      String @default("active")
  created_at  DateTime       @default(now())
  updated_at  DateTime       @default(now())
  customers   customers      @relation(fields: [customer_id], references: [id])

  @@index([customer_id], map: "idx_wallets_customer")
  @@index([status], map: "idx_wallets_status")
}


// ==========================================
// NEW FINTECH FEATURES ENUMS & TABLES
// ==========================================

model payment_splits {
  id             Int      @id @default(autoincrement())
  transaction_id Int
  merchant_id    Int
  amount         Float 
  currency       String   @default("INR")
  created_at     DateTime @default(now())

  transactions transactions @relation(fields: [transaction_id], references: [id])
  merchants    merchants    @relation(fields: [merchant_id], references: [id])

  @@index([transaction_id], map: "idx_split_txn")
  @@index([merchant_id], map: "idx_split_merchant")
}

model escrow_accounts {
  id          Int      @id @default(autoincrement())
  merchant_id Int?     @unique
  customer_id Int?     @unique
  balance     Float  @default(0.00)
  currency    String   @default("INR")
  status      String @default("active")
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  merchants           merchants?            @relation(fields: [merchant_id], references: [id])
  customers           customers?            @relation(fields: [customer_id], references: [id])
  escrow_transactions escrow_transactions[]
}

model escrow_transactions {
  id                Int           @id @default(autoincrement())
  escrow_account_id Int
  transaction_id    Int           @unique
  amount            Float      
  status            String @default("held")
  release_date      DateTime?    
  created_at        DateTime      @default(now())
  updated_at        DateTime      @default(now())

  escrow_account escrow_accounts @relation(fields: [escrow_account_id], references: [id])
  transactions   transactions    @relation(fields: [transaction_id], references: [id])

  @@index([escrow_account_id], map: "idx_escrow_txn_account")
  @@index([status], map: "idx_escrow_txn_status")
}

model subscriptions {
  id                Int                   @id @default(autoincrement())
  subscription_id   String                @unique
  customer_id       Int
  merchant_id       Int
  plan_name         String               
  amount            Float 
             
  currency          String                @default("INR")
  billing_interval  String
  status            String   @default("active")
  next_billing_date DateTime             
  payment_method_id Int
  created_at        DateTime              @default(now())
  updated_at        DateTime              @default(now())

  customers             customers               @relation(fields: [customer_id], references: [id])
  merchants             merchants               @relation(fields: [merchant_id], references: [id])
  payment_methods       payment_methods         @relation(fields: [payment_method_id], references: [id])
  subscription_payments subscription_payments[]

  @@index([customer_id], map: "idx_sub_customer")
  @@index([merchant_id], map: "idx_sub_merchant")
  @@index([next_billing_date, status], map: "idx_sub_billing")
}

model subscription_payments {
  id              Int            @id @default(autoincrement())
  subscription_id Int
  transaction_id  Int            @unique
  billing_date    DateTime      
  status          String @default("pending")
  created_at      DateTime       @default(now())

  subscriptions subscriptions @relation(fields: [subscription_id], references: [id])
  transactions  transactions  @relation(fields: [transaction_id], references: [id])

  @@index([subscription_id], map: "idx_sub_pay_sub")
}

model payment_attempts {
  id                Int            @id @default(autoincrement())
  session_id        Int?
  transaction_id    Int? // Only set if the attempt actually led to a transaction record
  customer_id       Int
  payment_method_id Int
  amount            Float       
  currency          String         @default("INR")
  status            String @default("pending")
  failure_reason    String?       
  attempt_sequence  Int            @default(1) // E.g. 1st try, 2nd try
  created_at        DateTime       @default(now())

  payment_sessions payment_sessions? @relation(fields: [session_id], references: [id])
  transactions     transactions?     @relation(fields: [transaction_id], references: [id])
  customers        customers         @relation(fields: [customer_id], references: [id])
  payment_methods  payment_methods   @relation(fields: [payment_method_id], references: [id])

  @@index([session_id], map: "idx_attempt_session")
  @@index([customer_id], map: "idx_attempt_customer")
}

model risk_scores {
  id             Int                   @id @default(autoincrement())
  customer_id    Int                   @unique
  risk_score     Int                   @default(0) // Scale 0 - 100
  risk_level     String @default("low")
  factors        String? // Array of reasons causing the score
  last_evaluated DateTime              @default(now())
  created_at     DateTime              @default(now())
  updated_at     DateTime              @default(now())

  customers customers @relation(fields: [customer_id], references: [id], onDelete: Cascade)
}

model verification_codes {
  id          Int      @id @default(autoincrement())
  email       String
  code        String
  type        String   // 'login', 'payment'
  expires_at  DateTime
  created_at  DateTime @default(now())

  @@index([email, code])
}

model audit_logs {
  id          Int      @id @default(autoincrement())
  customer_id Int
  action      String
  details     String?
  ip_address  String?
  created_at  DateTime @default(now())

  customer    customers @relation(fields: [customer_id], references: [id])
}
