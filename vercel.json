{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://paysim-payment-gateway.onrender.com/api/$1"
        },
        {
            "source": "/demo/(.*)",
            "destination": "/DEMO_ECOMMERCE/$1"
        },
        {
            "source": "/",
            "destination": "/public/login.html"
        },
        {
            "source": "/(.*)",
            "destination": "/public/$1"
        }
    ]
}